{
  "profile_id": "tabular_q_v2_momentum",
  "description": "V2 tabular Q-learning 모멘텀 + 기회비용 기반 설정",
  "algorithm": "tabular_q_learning",
  "state_version": "qlearn_v2",
  "trainer_params": {
    "lookback": 20,
    "episodes": 300,
    "learning_rate": 0.10,
    "discount_factor": 0.95,
    "epsilon": 0.30,
    "trade_penalty_bps": 2,
    "opportunity_cost_factor": 0.5,
    "random_seed": 42,
    "num_seeds": 5
  },
  "dataset": {
    "default_source": "yfinance",
    "default_range": "10y",
    "default_train_ratio": 0.7,
    "min_history_points": 40
  },
  "evaluation": {
    "min_approval_return_pct": 5.0,
    "max_drawdown_limit_pct": -50.0
  }
}
