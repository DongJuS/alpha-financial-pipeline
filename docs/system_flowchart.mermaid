%%{init: {'theme': 'base', 'themeVariables': {'primaryColor': '#1a1a2e', 'primaryTextColor': '#e0e0e0', 'primaryBorderColor': '#16213e', 'lineColor': '#0f3460', 'secondaryColor': '#533483', 'tertiaryColor': '#e94560'}}}%%

flowchart TD
    %% ============================================================
    %% agents-investing 전체 시스템 로직 플로우차트
    %% 작성일: 2026-03-15
    %% ============================================================

    START(["`⏰ **Orchestrator Cycle Start**
    APScheduler / Manual Trigger`"])

    START --> MH{"`장 상태 확인
    market_hours.py`"}
    MH -->|"장중 (09:00~15:30)"| COLLECT
    MH -->|"장외 / 주말 / 공휴일"| SKIP_MARKET["🔒 주문 생략\n(분석만 수행)"]

    %% ==================== 데이터 수집 ====================
    subgraph DATA_LAYER ["`📊 **데이터 수집 레이어**`"]
        COLLECT["KIS API\n실시간 시세 수집"]
        OHLCV["FinanceDataReader\nOHLCV 수집"]
        INDEX["Redis 지수 캐시\n(KOSPI/KOSDAQ)"]
        TICK_CACHE["Redis 틱 캐시\nlatest_ticks:{ticker}"]
        COLLECT --> TICK_CACHE
        COLLECT --> INDEX
        OHLCV --> PG_MARKET["PostgreSQL\nmarket_data"]
    end

    COLLECT --> STRATEGY_A
    COLLECT --> STRATEGY_B

    %% ==================== Strategy A ====================
    subgraph STRATEGY_A_LAYER ["`🏆 **Strategy A — Tournament**`"]
        direction TB
        STRATEGY_A["Strategy A Runner"]
        STRATEGY_A --> P1["🤖 Predictor 1\nClaude Opus · 가치투자형\ntemp=0.3"]
        STRATEGY_A --> P2["🤖 Predictor 2\nClaude Opus · 기술분석형\ntemp=0.5"]
        STRATEGY_A --> P3["🤖 Predictor 3\nGemini Pro · 모멘텀형\ntemp=0.7"]
        STRATEGY_A --> P4["🤖 Predictor 4\nGemini Pro · 역추세형\ntemp=0.6"]
        STRATEGY_A --> P5["🤖 Predictor 5\nClaude Haiku · 거시경제형\ntemp=0.4"]

        P1 & P2 & P3 & P4 & P5 --> LLM_CALL_A{"`LLM 호출
        + 포지션 컨텍스트`"}
        LLM_CALL_A -->|"성공"| SIGNAL_A["BUY / SELL / HOLD\n+ confidence"]
        LLM_CALL_A -->|"실패"| FALLBACK_A["Provider Fallback\nClaude → GPT → Gemini"]
        FALLBACK_A --> SIGNAL_A

        SIGNAL_A --> TOURNAMENT["토너먼트 점수 집계\nrolling_accuracy 기반"]
        TOURNAMENT --> WINNER["🏅 Winner 선정\n가장 높은 정확도"]
    end

    %% ==================== Strategy B ====================
    subgraph STRATEGY_B_LAYER ["`🗣️ **Strategy B — Consensus Debate**`"]
        direction TB
        STRATEGY_B["Strategy B Runner"]
        STRATEGY_B --> PROPOSER["💡 Proposer\ntemp=0.5\n매매 주장 제시"]
        PROPOSER --> CH1["⚔️ Challenger 1\ntemp=0.7\n반론 제시"]
        PROPOSER --> CH2["⚔️ Challenger 2\ntemp=0.7\n반론 제시"]
        CH1 & CH2 --> SYNTH["🧠 Synthesizer\ntemp=0.3\n종합 판단"]
        SYNTH --> CONSENSUS{"`합의 도달?
        conf ≥ threshold(0.67)`"}
        CONSENSUS -->|"합의 성공"| SIGNAL_B["시그널 확정\n(BUY/SELL/HOLD)"]
        CONSENSUS -->|"합의 실패"| NEXT_ROUND{"`다음 라운드?
        round < max_rounds`"}
        NEXT_ROUND -->|"Yes"| PROPOSER
        NEXT_ROUND -->|"No (소진)"| HOLD_B["HOLD 확정\nreason: max_rounds\nor confidence_below"]
    end

    %% ==================== 블렌딩 ====================
    subgraph BLEND_LAYER ["`🔀 **Signal Blending**`"]
        WINNER --> BLEND
        SIGNAL_B --> BLEND
        HOLD_B --> BLEND
        BLEND["blend_signals()\nN-way 가중 블렌딩\nstrategy_blend_weights"]
        BLEND --> FINAL_SIGNAL["최종 시그널\nBUY / SELL / HOLD\n+ combined_confidence"]
    end

    %% ==================== 포트폴리오 매니저 ====================
    subgraph PM_LAYER ["`💼 **Portfolio Manager**`"]
        direction TB
        FINAL_SIGNAL --> PM["PortfolioManagerAgent"]

        PM --> EXIT_CHECK{"`규칙 기반 매도 체크
        익절 ≥ +5% | 손절 ≤ -3%`"}
        EXIT_CHECK -->|"해당 포지션 있음"| FORCE_SELL["🔴 강제 SELL 시그널\nrule_based_exit"]
        EXIT_CHECK -->|"해당 없음"| PROCESS

        FORCE_SELL --> PROCESS
        PROCESS["시그널 처리 루프"]

        PROCESS --> CB_CHECK{"`일일 손실 한도?
        daily_loss_limit_pct`"}
        CB_CHECK -->|"한도 초과"| CIRCUIT["🚫 Circuit Breaker\n주문 차단"]
        CB_CHECK -->|"정상"| SIGNAL_TYPE

        SIGNAL_TYPE{"`시그널 종류`"}
        SIGNAL_TYPE -->|"BUY"| POS_CHECK{"`포지션 비중 초과?
        max_position_pct`"}
        POS_CHECK -->|"초과"| BUY_SKIP["⏭️ BUY 스킵"]
        POS_CHECK -->|"정상"| BUY_ORDER["✅ 매수 주문"]

        SIGNAL_TYPE -->|"SELL"| HAS_POS{"`보유 포지션?`"}
        HAS_POS -->|"Yes"| SELL_ORDER["✅ 매도 주문\n전량 청산"]
        HAS_POS -->|"No"| SELL_SKIP["⏭️ SELL 스킵"]

        SIGNAL_TYPE -->|"HOLD"| HOLD_SKIP["⏭️ 대기"]
    end

    %% ==================== 주문 실행 ====================
    subgraph BROKER_LAYER ["`🏦 **Broker Execution**`"]
        BUY_ORDER --> BROKER_ROUTE{"`계좌 구분`"}
        SELL_ORDER --> BROKER_ROUTE
        BROKER_ROUTE -->|"Paper"| PAPER_BROKER["KIS 페이퍼 브로커\n모의투자 체결"]
        BROKER_ROUTE -->|"Real"| REAL_BROKER["KIS 실거래 브로커\n실전투자 체결"]
        PAPER_BROKER --> EXEC_RESULT
        REAL_BROKER --> EXEC_RESULT
        EXEC_RESULT{"`체결 결과`"}
        EXEC_RESULT -->|"체결"| UPDATE_POS["포지션 업데이트\nportfolio_positions"]
        EXEC_RESULT -->|"거절"| LOG_REJECT["거절 로깅"]
    end

    %% ==================== 저장소 ====================
    subgraph DB_LAYER ["`🗄️ **Persistence**`"]
        PG_PRED["predictions"]
        PG_DEBATE["debate_transcripts"]
        PG_TOUR["predictor_tournament_scores"]
        PG_TRADE["trade_history"]
        PG_POS["portfolio_positions"]
        PG_ORDERS["broker_orders"]
        REDIS_HB["Redis heartbeats"]
    end

    SIGNAL_A --> PG_PRED
    SIGNAL_B --> PG_PRED
    HOLD_B --> PG_DEBATE
    SIGNAL_B --> PG_DEBATE
    TOURNAMENT --> PG_TOUR
    UPDATE_POS --> PG_POS
    UPDATE_POS --> PG_TRADE
    UPDATE_POS --> PG_ORDERS

    %% ==================== 알림 ====================
    subgraph NOTIFY_LAYER ["`📢 **Notifications**`"]
        UPDATE_POS --> TELEGRAM["Telegram 알림\n체결 결과 통보"]
        CIRCUIT --> TELEGRAM
    end

    %% ==================== 하트비트 ====================
    PM --> REDIS_HB
    STRATEGY_A --> REDIS_HB
    SKIP_MARKET --> REDIS_HB

    %% ==================== 스타일 ====================
    classDef critical fill:#e94560,stroke:#e94560,color:#fff
    classDef success fill:#0f9b58,stroke:#0f9b58,color:#fff
    classDef warning fill:#f39c12,stroke:#f39c12,color:#fff
    classDef info fill:#3498db,stroke:#3498db,color:#fff

    class CIRCUIT,FORCE_SELL critical
    class BUY_ORDER,SELL_ORDER,UPDATE_POS success
    class FALLBACK_A,HOLD_B warning
    class BLEND,FINAL_SIGNAL info
