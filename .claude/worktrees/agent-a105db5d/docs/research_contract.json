{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ResearchContract",
  "description": "Final research output contract from SearchAgent (hybrid pipeline)",
  "type": "object",
  "required": [
    "query",
    "timestamp_utc",
    "sentiment",
    "confidence",
    "summary"
  ],
  "properties": {
    "ticker": {
      "type": ["string", "null"],
      "description": "Stock ticker symbol (e.g., '259960' for Krafton)"
    },
    "query": {
      "type": "string",
      "description": "Original search query"
    },
    "timestamp_utc": {
      "type": "string",
      "format": "date-time",
      "description": "Research completion timestamp (ISO 8601)"
    },
    "sources": {
      "type": "array",
      "description": "List of sources used in research",
      "items": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "description": "Source URL (canonical)"
          },
          "title": {
            "type": ["string", "null"],
            "description": "Page title"
          },
          "source_id": {
            "type": ["integer", "null"],
            "description": "Database search_results.id"
          },
          "published_at": {
            "type": ["string", "null"],
            "format": "date-time",
            "description": "Article/content publish date (if available)"
          },
          "retrieved_at": {
            "type": ["string", "null"],
            "format": "date-time",
            "description": "When content was fetched"
          },
          "extraction_status": {
            "type": "string",
            "enum": ["extracted", "partial", "failed"],
            "description": "Status of content extraction"
          }
        }
      }
    },
    "sentiment": {
      "type": "string",
      "enum": ["bullish", "bearish", "neutral", "mixed"],
      "description": "Overall sentiment assessment"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Confidence score (0.0-1.0)"
    },
    "key_facts": {
      "type": "array",
      "description": "Key findings from research",
      "items": {
        "type": "string"
      }
    },
    "risk_factors": {
      "type": "array",
      "description": "Risk factors identified",
      "items": {
        "type": "string"
      }
    },
    "summary": {
      "type": "string",
      "description": "2-3 sentence executive summary"
    },
    "model_used": {
      "type": "string",
      "description": "Claude model used for reasoning (e.g., 'claude-3-5-sonnet-latest')"
    }
  }
}
