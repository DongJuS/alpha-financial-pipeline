# ============================================================
# Alpha Trading System — 환경 변수 템플릿
# 이 파일을 복사하여 .env 로 사용하세요: cp .env.example .env
# ⚠️  .env 파일은 절대 git에 커밋하지 마세요!
# ============================================================

# ── Git / GitHub ───────────────────────────────────────────────────────────────────────────
# GitHub Personal Access Token (repo 권한 필요)
# 발급: https://github.com/settings/tokens → "Generate new token (classic)" → repo 체크
# AI 에이전트가 git push 시 이 값을 읽어 인증에 사용합니다 (CLAUDE.md 참고)
GITHUB_TOKEN=ghp_여기에토큰값_입력

# ── App ────────────────────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8000
APP_URL=http://localhost:8000

# ── Database / Redis ──────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://alpha_user:alpha_pass@localhost:5432/alpha_db
REDIS_URL=redis://localhost:6379/0

# ── Auth (JWT) ─────────────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d

# ── LLM (API 키 사용 안 함 — CLI/OAuth 모드) ──────────────────────────────────────────────
# Claude: CLI 모드 사용. 호스트의 ~/.claude를 Docker에 마운트.
ANTHROPIC_API_KEY=
ANTHROPIC_CLI_COMMAND=claude

# GPT: 사용 안 함.
OPENAI_API_KEY=

# ── Tavily Search API ──────────────────────────────────────────────────────────────────────
TAVILY_API_KEY=

# Gemini: OAuth(ADC) 모드 사용. 호스트의 ~/.config/gcloud를 Docker에 마운트.
# 사전 설정: gcloud auth application-default login
GOOGLE_APPLICATION_CREDENTIALS=
GEMINI_API_KEY=

LLM_CLI_TIMEOUT_SECONDS=90

# ── KIS Developers 공통 fallback (legacy) ──────────────────────────────────────────────────
# split key가 비어 있을 때 fallback으로 사용됩니다.
KIS_APP_KEY=PSXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
KIS_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 계좌번호 형식: 8자리 계좌번호 + 2자리 상품코드 (예: 50123456-01 -> 5012345601)
KIS_ACCOUNT_NUMBER=5012345601
KIS_IS_PAPER_TRADING=true

# ── KIS Paper 계좌 (권장: 명시적으로 분리) ──────────────────────────────────────────────────
KIS_PAPER_APP_KEY=
KIS_PAPER_APP_SECRET=
KIS_PAPER_ACCOUNT_NUMBER=

# ── KIS Real 계좌 (권장: 명시적으로 분리) ────────────────────────────────────────────────────
KIS_REAL_APP_KEY=
KIS_REAL_APP_SECRET=
KIS_REAL_ACCOUNT_NUMBER=

# ── Broker backends ───────────────────────────────────────────────────────────────────────
PAPER_BROKER_BACKEND=internal
REAL_BROKER_BACKEND=kis
KIS_REQUEST_TIMEOUT_SECONDS=15

# ── Telegram Bot ───────────────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=123456789

# ── Strategy / Readiness ───────────────────────────────────────────────────────────────────
STRATEGY_BLEND_RATIO=0.50
STRATEGY_BLEND_WEIGHTS={"A": 0.30, "B": 0.30, "RL": 0.20, "S": 0.20}
STRATEGY_A_ROLLING_DAYS=5
STRATEGY_A_MIN_SAMPLES=3
STRATEGY_B_MAX_ROUNDS=2
STRATEGY_B_CONSENSUS_THRESHOLD=0.67
SEARCH_MAX_CONCURRENT=3
SEARCH_CATEGORIES=news
SEARCH_MAX_SOURCES=5
REAL_TRADING_CONFIRMATION_CODE=CONFIRM_REAL_TRADING_2026
READINESS_REQUIRED_PAPER_DAYS=30
READINESS_AUDIT_MAX_AGE_DAYS=7

# ── Orchestrator Worker ────────────────────────────────────────────────────────────────────
ORCH_MODE=blend
ORCH_TICKERS=
ORCH_INTERVAL_SECONDS=600
ORCH_RUN_ONCE=false
ORCH_ENABLE_DAILY_REPORT=false
ORCH_DAILY_REPORT_HOUR=17
ORCH_DAILY_REPORT_MINUTE=10
ORCH_TOURNAMENT_ROLLING_DAYS=
ORCH_TOURNAMENT_MIN_SAMPLES=
ORCH_CONSENSUS_ROUNDS=
ORCH_CONSENSUS_THRESHOLD=

# ── Blog Auto-Posting (Google Blogger) ─────────────────────────────────────────────────────
BLOGGER_BLOG_ID=
BLOGGER_CLIENT_ID=
BLOGGER_CLIENT_SECRET=
BLOGGER_REFRESH_TOKEN=

# ── Logging ────────────────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
