# ============================================================
# Alpha Trading System — 환경 변수 템플릿
# 이 파일을 복사하여 .env 로 사용하세요: cp .env.example .env
# ⚠️  .env 파일은 절대 git에 커밋하지 마세요!
# ============================================================

# ── App ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=8000
APP_URL=http://localhost:8000

# ── Database (PostgreSQL) ────────────────────────────────────
DATABASE_URL=postgresql://alpha_user:alpha_pass@localhost:5432/alpha_db

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth (JWT) ───────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d

# ── LLM APIs ─────────────────────────────────────────────────
# Claude: CLI 우선, SDK 폴백
ANTHROPIC_API_KEY=sk-ant-...

# GPT-4o: Strategy A Tournament 인스턴스 3,4 + Strategy B Challenger 1
OPENAI_API_KEY=sk-...

# Gemini: Strategy A Tournament 인스턴스 5 + Strategy B Challenger 2
GEMINI_API_KEY=AI...

# ── KIS Developers (한국투자증권) ────────────────────────────
# https://apiportal.koreainvestment.com 에서 앱 등록 후 발급
KIS_APP_KEY=PSXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
KIS_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 계좌번호 (예: 50123456-01 → 5012345601)
KIS_ACCOUNT_NUMBER=5012345601
# true = 페이퍼 트레이딩, false = 실거래 (기본값: true — 절대 함부로 false 변경 금지!)
KIS_IS_PAPER_TRADING=true

# ── Telegram Bot ─────────────────────────────────────────────
# @BotFather에서 봇 생성 후 발급
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 개인 채팅 또는 그룹 채팅 ID (음수일 수 있음)
TELEGRAM_CHAT_ID=123456789

# ── Strategy ─────────────────────────────────────────────────
# 0.0 = Strategy A 100%, 1.0 = Strategy B 100%, 0.5 = 50/50 블렌드
STRATEGY_BLEND_RATIO=0.50
# Strategy A 토너먼트 점수 롤링 윈도우(일)
STRATEGY_A_ROLLING_DAYS=5
# Strategy A 우승자 선정을 위한 최소 채점 샘플 수
STRATEGY_A_MIN_SAMPLES=3
# Strategy B 최대 토론 라운드 수 (1~5)
STRATEGY_B_MAX_ROUNDS=2
# Strategy B 합의 confidence 임계치 (0.0~1.0)
STRATEGY_B_CONSENSUS_THRESHOLD=0.67
# 실거래 전환 확인 코드(반드시 프로젝트별 고유값으로 변경)
REAL_TRADING_CONFIRMATION_CODE=CONFIRM_REAL_TRADING_2026
# readiness: 실거래 전환 전 필요한 최소 페이퍼 운용 일수
READINESS_REQUIRED_PAPER_DAYS=30
# readiness: security/risk 운영 감사 통과 인정 최대 경과 일수
READINESS_AUDIT_MAX_AGE_DAYS=7

# ── Orchestrator Worker (Docker 루프 실행) ─────────────────────
# single | tournament | consensus | blend
ORCH_MODE=blend
# 쉼표 구분 종목 코드 (비우면 Collector 기본 종목 사용)
ORCH_TICKERS=
# 실행 주기(초)
ORCH_INTERVAL_SECONDS=600
# true면 1회 실행 후 종료
ORCH_RUN_ONCE=false
# true면 일일 페이퍼 리포트 자동 발송(NotifierAgent)
ORCH_ENABLE_DAILY_REPORT=false
# 리포트 발송 시각(KST)
ORCH_DAILY_REPORT_HOUR=17
ORCH_DAILY_REPORT_MINUTE=10
# Strategy A override (비우면 Settings 기본값 사용)
ORCH_TOURNAMENT_ROLLING_DAYS=
ORCH_TOURNAMENT_MIN_SAMPLES=
# Strategy B override (비우면 Settings 기본값 사용)
ORCH_CONSENSUS_ROUNDS=
ORCH_CONSENSUS_THRESHOLD=

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
