{
  "annotations": { "list": [] },
  "description": "Alpha Trading System — 운영 대시보드",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "API Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(http_requests_total{job=\"alpha-api\"}[5m])",
          "legendFormat": "{{method}} {{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "title": "API Response Latency (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"alpha-api\"}[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket{job=\"alpha-api\"}[5m]))",
          "legendFormat": "p50"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Orchestrator Cycle Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "alpha_orchestrator_cycle_total",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "title": "Active Strategies",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "targets": [
        {
          "expr": "alpha_active_strategies_count",
          "legendFormat": "strategies"
        }
      ]
    },
    {
      "title": "Blending Fallback Events",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "alpha_blending_fallback_total",
          "legendFormat": "fallbacks"
        }
      ]
    },
    {
      "title": "Orders Executed",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "targets": [
        {
          "expr": "increase(alpha_orders_total[1h])",
          "legendFormat": "last 1h"
        }
      ]
    },
    {
      "title": "PostgreSQL Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "pg_stat_activity_count{job=\"postgres\"}",
          "legendFormat": "{{state}}"
        }
      ]
    },
    {
      "title": "Redis Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "redis_memory_used_bytes{job=\"redis\"}",
          "legendFormat": "used"
        },
        {
          "expr": "redis_memory_max_bytes{job=\"redis\"}",
          "legendFormat": "max"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      }
    },
    {
      "title": "Pod CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{namespace=\"alpha-trading\"}[5m])",
          "legendFormat": "{{pod}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit" }
      }
    },
    {
      "title": "Pod Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "expr": "container_memory_working_set_bytes{namespace=\"alpha-trading\"}",
          "legendFormat": "{{pod}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["alpha-trading", "k3s"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "title": "Alpha Trading System",
  "uid": "alpha-trading-main"
}
